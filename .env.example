PORT=1060
HOST=0.0.0.0
DATA_DIR=./data

# Comma-separated extra origins for non-Spotify browser integrations.
# Normal LAN/Tailscale access only needs HOST=0.0.0.0, not this setting.
# The app always allows Spotify Desktop origins and local loopback origins.
CORS_ALLOWED_ORIGINS=

# Backup uploads are staged under DATA_DIR before restore/merge.
# Value is bytes; default is 5368709120.
BACKUP_UPLOAD_MAX_BYTES=5368709120
